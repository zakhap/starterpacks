# Packrat environment. Copy to .env.local and fill in.
# Required vars are checked at startup (src/lib/env.ts) — the app refuses to boot without them.

# --- Database (local Postgres in dev; Supabase Postgres in prod) ---
DATABASE_URL=postgres://USER@localhost:5432/packrat

# --- App ---
# Public base URL, used for absolute OG/share URLs. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Storage (share images) ---
# dev: "local" writes to public/uploads. prod: "r2" (see src/lib/storage).
STORAGE_DRIVER=local
# R2 (prod only) — leave blank in dev:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# --- Auth ---
# dev: "dev" = cookie-session pick-a-handle (no OAuth). prod: "supabase".
AUTH_DRIVER=dev
