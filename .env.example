# Packrat environment. Copy to .env.local (dev) and fill in.
# Required vars are validated at startup (src/lib/env.ts) — the app refuses to boot without them.

# --- Database ---
# dev: local Postgres. prod: Supabase DIRECT connection string
# (Settings → Database → Connection string → URI; use the direct/session one, not the pooler).
DATABASE_URL=postgres://USER@localhost:5432/packrat

# --- App ---
# Public base URL. Used for absolute OG/share-image URLs (must be the real domain in prod,
# or link previews break). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Storage (share images) ---
# dev: "local" (writes to public/uploads). prod: "r2".
STORAGE_DRIVER=local

# --- Cloudflare R2 (prod only; required when STORAGE_DRIVER=r2) ---
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=r2_access_key
# R2_SECRET_ACCESS_KEY=r2_secret_key
# R2_BUCKET=packrat-images
# R2_PUBLIC_URL=https://images.yourdomain.com   # R2 public bucket URL or custom domain
